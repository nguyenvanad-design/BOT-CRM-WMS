# Tokinarc V6 — .env.example
# Copy thành .env và điền giá trị thật. KHÔNG commit file .env (đã .gitignore).

# ─── Django ────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=tokinarc.settings.production
DJANGO_SECRET_KEY=<thay-bang-string-50-ky-tu-random>
DJANGO_ALLOWED_HOSTS=tokinarc.vn,internal.tokinarc.vn
DJANGO_CORS_ORIGINS=https://app.tokinarc.vn
DJANGO_CSRF_TRUSTED=https://app.tokinarc.vn,https://internal.tokinarc.vn

# ─── Postgres ──────────────────────────────────────────────────────────────
PGHOST=postgres
PGPORT=5432
PGDATABASE=tokinarc
PGUSER=tokinarc
PGPASSWORD=<random-strong-password>

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL_CACHE=redis://redis:6379/0
REDIS_URL_RATELIMIT=redis://redis:6379/1

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_BUCKET=tokinarc-files
MINIO_BACKUP_ALIAS=backup

# ─── JWT (RS256 — khớp secrets mount) ──────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_AUDIENCE=tokinarc-api
JWT_ISSUER=tokinarc
JWT_KID=2026-06       # bump khi rotate
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public

# ─── Chatbot sidecar ───────────────────────────────────────────────────────
DJANGO_JWKS_URL=http://django:8000/.well-known/jwks.json
DJANGO_BASE_URL=http://django:8000
ALLOW_HS256_DEV=0     # production: 0; local dev có thể =1
TOKINARC_API_KEY=<legacy-api-key-cho-zalo-bot-chua-migrate-jwt>
TOKINARC_CORS_ORIGINS=https://chat.tokinarc.vn

# ─── Gemini / LLM ──────────────────────────────────────────────────────────
# Để TRỐNG → chatbot chạy chế độ dev (stub, không gọi LLM). Đặt key → bật thật.
GEMINI_API_KEY=<your-key>      # ưu tiên; hoặc dùng GOOGLE_API_KEY (tên cũ)
GOOGLE_API_KEY=<your-key>
GEMINI_MODEL=gemini-2.0-flash

# ─── Observability (optional) ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
